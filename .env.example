NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The Chrome extension's ID, used by ExtensionAuthBridge to relay the Supabase
# session to the extension via chrome.runtime.sendMessage. Chrome does not
# expose a way for a web page to discover an installed extension's ID, so this
# must be set manually per environment:
#   - Local dev: load extension/dist unpacked in chrome://extensions and copy
#     the ID shown there (stable per machine as long as the dist/ path doesn't
#     move).
#   - Production: copy the permanent ID Chrome assigns after the extension is
#     first uploaded to the Chrome Web Store developer dashboard.
# If unset, the web app still works standalone — the auth bridge just no-ops.
NEXT_PUBLIC_POKEBROWSE_EXTENSION_ID=
