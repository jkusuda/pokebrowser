{
    "manifest_version": 3,
    "name": "Pokebrowser",
    "description": "Wild Pokemon appear while you browse the web. Catch them, build your collection, and track your progress.",
    "version": "1.0.0",
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "storage"
    ],
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["assets/content.js"],
            "run_at": "document_idle"
        }
    ],
    "externally_connectable": {
        "matches": [
            "http://localhost:3000/*",
            "https://pokebrowser.net/*",
            "https://www.pokebrowser.net/*"
        ]
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Pokebrowser",
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": ["grass-platform.webp", "pokeball-spritesheet.png"],
            "matches": ["<all_urls>"]
        }
    ]
}
